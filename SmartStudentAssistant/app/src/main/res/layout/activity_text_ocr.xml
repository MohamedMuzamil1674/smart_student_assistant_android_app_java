<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/text_ocr_screen"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".imagescontents.ContentActivity">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/screen_label_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginTop="@dimen/dimen_15"
        android:layout_marginBottom="@dimen/dimen_3"
        android:fontFamily="@font/norican"
        android:letterSpacing="0.1"
        android:paddingStart="@dimen/font_5"
        android:paddingEnd="@dimen/font_5"
        android:text="Image to text Scanning"
        android:textColor="@color/black"
        android:textSize="@dimen/font_25"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />

    <ImageView
        android:id="@+id/docs_scan_img"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="@dimen/dimen_180"
        android:contentDescription="Image design for document Scan"
        android:src="@drawable/text_recognize_img"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/screen_label_txt" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_ocr_text"
        android:layout_width="@dimen/dimen_360"
        android:layout_height="wrap_content"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/dimen_15"
        app:boxCornerRadiusBottomStart="@dimen/dimen_15"
        app:boxCornerRadiusTopEnd="@dimen/dimen_15"
        app:boxCornerRadiusTopStart="@dimen/dimen_15"
        app:boxStrokeColor="@color/black"
        app:boxStrokeWidth="@dimen/dimen_2"
        app:boxStrokeWidthFocused="@dimen/dimen_2"
        app:hintTextAppearance="@style/TextAppearance.AppCompat.Medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/docs_scan_img">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/img_extracted_text"
            android:layout_width="@dimen/dimen_360"
            android:layout_height="wrap_content"
            android:fontFamily="@font/merriweather"
            android:gravity="start|top"
            android:hint="Output Content"
            android:inputType="textMultiLine"
            android:lines="16"
            android:maxLines="22"
            android:overScrollMode="always"
            android:scrollbars="vertical"
            android:scrollHorizontally="false"
            android:textColor="@color/black"
            android:textSize="@dimen/font_15"
            android:textStyle="bold"
            app:hintTextColor="@color/black" />

    </com.google.android.material.textfield.TextInputLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/My_Relative_Layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/dimen_6"
        android:paddingBottom="@dimen/dimen_6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_ocr_text"
        app:layout_constraintVertical_bias="0.925">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/img_clear_text"
            android:layout_width="@dimen/dimen_44"
            android:layout_height="@dimen/dimen_44"
            android:layout_marginStart="@dimen/dimen_5"
            android:scaleType="fitCenter"
            android:src="@drawable/clear_text"
            app:layout_constraintEnd_toStartOf="@+id/img_pick_icon"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/img_pick_icon"
            android:layout_width="@dimen/dimen_55"
            android:layout_height="@dimen/dimen_44"
            android:scaleType="fitCenter"
            android:src="@drawable/image_camera_icon"
            app:layout_constraintEnd_toStartOf="@+id/img_copy_text"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/img_clear_text"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/img_copy_text"
            android:layout_width="@dimen/dimen_44"
            android:layout_height="@dimen/dimen_44"
            android:layout_marginEnd="@dimen/dimen_5"
            android:scaleType="fitCenter"
            android:src="@drawable/note_book_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/img_pick_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/clear_text_label"
            android:layout_width="@dimen/dimen_55"
            android:layout_height="wrap_content"
            android:fontFamily="@font/merriweather"
            android:gravity="center_horizontal"
            android:text="Clear"
            android:textColor="@color/black"
            android:textSize="@dimen/font_13"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/pick_text_label"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/img_clear_text" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/pick_text_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/merriweather"
            android:text="Pick_image"
            android:textColor="@color/black"
            android:textSize="@dimen/font_13"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/copy_text_label"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/clear_text_label"
            app:layout_constraintTop_toBottomOf="@+id/img_pick_icon" />


        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/copy_text_label"
            android:layout_width="@dimen/dimen_55"
            android:layout_height="wrap_content"
            android:fontFamily="@font/merriweather"
            android:gravity="center_horizontal"
            android:text="Copy"
            android:textColor="@color/black"
            android:textSize="@dimen/font_13"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/pick_text_label"
            app:layout_constraintTop_toBottomOf="@+id/img_copy_text" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>