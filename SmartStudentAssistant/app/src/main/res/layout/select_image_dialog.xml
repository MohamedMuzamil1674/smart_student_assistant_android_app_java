<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/dimen_360"
    android:layout_height="@dimen/dimen_200"
    android:layout_gravity="center_horizontal"
    android:background="@drawable/gradient_bg_one"
    android:orientation="vertical">

    <TextView
        android:id="@+id/txt_study_notes"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_44"
        android:fontFamily="@font/norican"
        android:gravity="center_vertical|center_horizontal"
        android:letterSpacing="0.09"
        android:paddingStart="@dimen/font_5"
        android:paddingEnd="@dimen/font_5"
        android:layout_marginTop="@dimen/dimen_10"
        android:text="Select an app to pick your image ?"
        android:textColor="@color/black"
        android:textSize="@dimen/font_18"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_device_camera"
        android:layout_width="@dimen/dimen_110"
        android:layout_height="@dimen/dimen_110"
        android:layout_marginTop="@dimen/dimen_10"
        app:cardCornerRadius="@dimen/dimen_15"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintEnd_toStartOf="@+id/card_device_gallery"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_study_notes">

        <RelativeLayout
            android:id="@+id/layout_drive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/dimen_4"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_drive"
                android:layout_width="@dimen/dimen_66"
                android:layout_height="@dimen/dimen_55"
                android:layout_centerHorizontal="true"
                android:scaleType="fitCenter"
                android:src="@drawable/image_camera_icon" />

            <TextView
                android:id="@+id/txt_drive"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_33"
                android:layout_below="@+id/img_drive"
                android:layout_marginTop="@dimen/dimen_2"
                android:fontFamily="@font/norican"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:text="device camera"
                android:textColor="@color/black"
                android:textSize="@dimen/font_15" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_device_gallery"
        android:layout_width="@dimen/dimen_110"
        android:layout_height="@dimen/dimen_110"
        android:layout_marginTop="@dimen/dimen_10"
        app:cardCornerRadius="@dimen/dimen_15"
        android:layout_marginBottom="@dimen/dimen_15"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/card_device_camera"
        app:layout_constraintTop_toBottomOf="@+id/txt_study_notes">

        <RelativeLayout
            android:id="@+id/layout_browser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/dimen_4"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_browser"
                android:layout_width="@dimen/dimen_66"
                android:layout_height="@dimen/dimen_55"
                android:layout_centerHorizontal="true"
                android:scaleType="fitCenter"
                android:src="@drawable/gallery_icon_img" />

            <TextView
                android:id="@+id/txt_browser"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_33"
                android:layout_below="@+id/img_browser"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/dimen_2"
                android:fontFamily="@font/norican"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:text="device gallery"
                android:textColor="@color/black"
                android:textSize="@dimen/font_15" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
