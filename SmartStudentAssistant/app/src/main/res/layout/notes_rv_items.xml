<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dimen_10"
    android:layout_marginEnd="@dimen/dimen_10"
    android:layout_marginStart="@dimen/dimen_10"
    android:layout_gravity="center_horizontal"
    app:cardCornerRadius="@dimen/dimen_15"
    app:cardBackgroundColor="#B3E5FC">

    <RelativeLayout
        android:id="@+id/MyActivityLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txt_notes_subject"
            android:layout_width="@dimen/dimen_350"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_alignParentTop="true"
            android:layout_marginTop="@dimen/dimen_5"
            android:fontFamily="cursive"
            android:textStyle="bold"
            android:text="Subject name"
            android:textColor="@color/black"
            android:textSize="@dimen/font_20"
            android:letterSpacing="0.06"
            android:gravity="center" />

        <TextView
            android:id="@+id/txt_subjects_link"
            android:layout_width="@dimen/dimen_350"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_below="@+id/txt_notes_subject"
            android:fontFamily="cursive"
            android:textStyle="bold"
            android:text="drive link"
            android:textColor="@color/black"
            android:textSize="@dimen/font_20"
            android:textColorLink="@color/black"
            android:letterSpacing="0.06"
            android:gravity="center_horizontal"
            android:padding="@dimen/dimen_5"/>

    </RelativeLayout>


</com.google.android.material.card.MaterialCardView>